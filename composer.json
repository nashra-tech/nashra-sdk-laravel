{
    "name": "nashra/sdk",
    "description": "Official PHP SDK for the Nashra API",
    "keywords": ["nashra", "sdk", "email", "newsletter", "api"],
    "license": "MIT",
    "type": "library",
    "require": {
        "php": "^8.2",
        "illuminate/http": "^11.0|^12.0",
        "illuminate/support": "^11.0|^12.0"
    },
    "require-dev": {
        "orchestra/testbench": "^9.0|^10.0",
        "pestphp/pest": "^3.0"
    },
    "autoload": {
        "psr-4": {
            "Nashra\\Sdk\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Nashra\\Sdk\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Nashra\\Sdk\\NashraServiceProvider"
            ],
            "aliases": {
                "Nashra": "Nashra\\Sdk\\Facades\\Nashra"
            }
        }
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true,
    "scripts": {
        "test": "vendor/bin/pest"
    }
}
